VITE_GITHUB_CLIENT_ID=
VITE_GITHUB_REDIRECT_URI=http://localhost:5173/auth/callback
VITE_OAUTH_PROXY_URL=
VITE_CONTENT_REPO_OWNER=
VITE_CONTENT_REPO_NAME=
VITE_ALLOWED_USERS=
# Absolute site URL used to generate `dist/sitemap.xml` (optional in local dev).
VITE_SITE_URL=
# Optional: appended to `/media/*` as `?v=` to avoid cached 404s after fresh uploads.
VITE_ASSET_VERSION=
# For GitHub Pages project sites, set to "/<repo-name>/"
VITE_BASE_PATH=/
# Local dev without GitHub auth: true/1
VITE_LOCAL_MODE=true
